{
  "name": "@walletwall/whale-watcher",
  "version": "1.0.0",
  "description": "Whale Watcher — wallet activity intelligence for Web3. Inspect movement, activity cadence, transfer spikes, counterparties, and quantum exposure for any Ethereum address.",
  "engines": {
    "node": "24.x"
  },
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n API,Vite -c cyan,magenta \"cross-env PORT=3001 NODE_OPTIONS=--use-system-ca node server.js\" \"vite\"",
    "api": "node server.js",
    "build": "vite build",
    "lint": "node scripts/static-check.mjs",
    "test": "node --test \"test/**/*.test.mjs\"",
    "security:audit": "npm audit --audit-level=moderate",
    "check": "npm run lint && npm run test && npm run build && npm run security:audit",
    "preview": "vite preview",
    "start": "node server.js"
  },
  "dependencies": {
    "@fontsource-variable/manrope": "^5.2.8",
    "@fontsource-variable/sora": "^5.2.8",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/manrope": "^5.2.5",
    "@fontsource/sora": "^5.2.5",
    "@vercel/analytics": "^2.0.1",
    "ethers": "^6.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/plugin-transform-react-jsx": "^7.29.7",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "prop-types": "^15.8.1",
    "vite": "^8.0.16"
  },
  "overrides": {
    "ws": "^8.20.2"
  }
}

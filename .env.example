# ── Required ─────────────────────────────────────────────────────────────────
# Sign session JWTs. Use a random string of at least 32 characters.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# ── Recommended (rate limiting) ───────────────────────────────────────────────
# Upstash Redis REST API for durable rate limits across serverless instances.
# Without this, rate limits are in-memory only and reset between cold starts.
# Create a free database at https://upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Dune Analytics (required for whale activity data) ────────────────────────
# Get your key at https://dune.com/settings/api
DUNE_API_KEY=

# Numeric ID of your 12-week wallet activity Dune query (integer, e.g. 1234567).
# This query must return per-wallet, per-day activity rows.
# See README.md for the expected schema and column names.
DUNE_QUERY_12WK_ACTIVE_WALLETS=

# ── On-chain data providers (recommended) ────────────────────────────────────
# Wallet profile, portfolio, and activity data.
# Without these the app falls back to mock data.
ETHERSCAN_API_KEY=
ALCHEMY_API_KEY=

# ── AI narrative (optional) ───────────────────────────────────────────────────
# First available provider wins. Omit all to disable AI summaries.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
# e.g. openai/gpt-4o, anthropic/claude-sonnet-4-5 — see openrouter.ai/models

OPENAI_API_KEY=
OPENAI_MODEL=
# e.g. gpt-4o-mini

ANTHROPIC_API_KEY=
# Model is pinned in api/_ai-providers.js

# ── CORS (optional, for non-Vercel deployments) ───────────────────────────────
# Space or comma-separated list of allowed origins.
# Vercel same-origin deployments do not need this.
ALLOWED_ORIGINS=
